# Eulerpool Financial Data API
# Get your free key at: https://eulerpool.com/developers/register
EULERPOOL_API_KEY=your_eulerpool_api_key_here

# Optional: SQLite URL (default: sqlite+aiosqlite:///data/stock_analysis.db).
# On Railway, mount a volume at /app/data and keep the default unless you use another DB.
# DATABASE_URL=sqlite+aiosqlite:///data/stock_analysis.db

# Email Notifications (signal alerts)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
NOTIFY_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
